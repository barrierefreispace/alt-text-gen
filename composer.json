{
  "name": "barrierefrei-space/alt-text-gen",
  "description": "TYPO3 extension for AI-powered accessible image alt text generation.",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "homepage": "https://www.barrierefrei.space",
  "keywords": [
    "TYPO3",
    "accessibility",
    "alt-text",
    "AI",
    "WCAG"
  ],
  "authors": [
    {
      "name": "Veritium GmbH",
      "email": "contact@barrierefrei.space"
    }
  ],
  "support": {
    "issues": "https://github.com/barrierefreispace/alt-text-gen/issues",
    "source": "https://github.com/barrierefreispace/alt-text-gen"
  },
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "BarrierefreiSpace\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "barrierefrei_space"
    }
  }
}